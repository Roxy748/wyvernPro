-- 🎯 [TARGETING LOGIC]
local FOVCircle = Drawing.new("Circle")
FOVCircle.Thickness = 1
FOVCircle.Color = Color3.fromRGB(0, 255, 255)

local function GetTarget()
    local Target, MaxDist = nil, _G.FOV
    for _, v in pairs(game.Players:GetPlayers()) do
        if v ~= game.Players.LocalPlayer and v.Character and v.Character:FindFirstChild("Head") then
            local pos, vis = workspace.CurrentCamera:WorldToViewportPoint(v.Character.Head.Position)
            if vis then
                local mag = (Vector2.new(pos.X, pos.Y) - game:GetService("UserInputService"):GetMouseLocation()).Magnitude
                if mag < MaxDist then MaxDist = mag Target = v.Character.Head end
            end
        end
    end
    return Target
end

-- 🔄 [MAIN LOOP]
game:GetService("RunService").RenderStepped:Connect(function()
    FOVCircle.Visible = true
    FOVCircle.Radius = _G.FOV
    FOVCircle.Position = game:GetService("UserInputService"):GetMouseLocation()

    local lp = game.Players.LocalPlayer
    local Char = lp.Character
    if Char and Char:FindFirstChild("HumanoidRootPart") then
        -- Speed Bypass
        if _G.WalkSpeed > 16 then
            Char.HumanoidRootPart.CFrame = Char.HumanoidRootPart.CFrame + (Char.Humanoid.MoveDirection * (_G.WalkSpeed / 120))
        end
        -- Bhop
        if _G.Bhop and game:GetService("UserInputService"):IsKeyDown(Enum.KeyCode.Space) and Char.Humanoid.FloorMaterial ~= Enum.Material.Air then
            Char.Humanoid.Jump = true
        end
    end

    -- Aimbot Execution
    if _G.AimbotEnabled and game:GetService("UserInputService"):IsKeyDown(Enum.KeyCode[_G.AimKey]) then
        local Target = GetTarget()
        if Target then
            workspace.CurrentCamera.CFrame = CFrame.new(workspace.CurrentCamera.CFrame.Position, Target.Position)
        end
    end
end)

