-- --- 🛠️ FONKSİYONLAR ---
local function CreateBtn(name, configPath)
    local b = Instance.new("TextButton", Main)
    b.Size = UDim2.new(0, 220, 0, 40)
    b.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    b.Text = name .. ": KAPALI"
    b.TextColor3 = Color3.new(1,1,1)
    Instance.new("UICorner", b)

    b.MouseButton1Click:Connect(function()
        WyvernConfig[configPath] = not WyvernConfig[configPath]
        b.Text = name .. (WyvernConfig[configPath] and ": AÇIK" or ": KAPALI")
        b.TextColor3 = WyvernConfig[configPath] and Color3.fromRGB(0, 255, 150) or Color3.new(1,1,1)
    end)
end

