-- [[ WYVERN PRO - XENO ULTIMATE REPAIR ]]
print("Wyvern Pro: Baslatiliyor...")

local success, Rayfield = pcall(function()
    return loadstring(game:HttpGet('https://raw.githubusercontent.com/shlexware/Rayfield/main/source'))()
end)

if not success or not Rayfield then
    warn("HATA: Rayfield yuklenemedi! İnternet veya Executor sorunu.")
    -- Eğer üstteki çalışmazsa alternatif linki dene
    Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()
end

print("Wyvern Pro: UI Kütüphanesi Hazır.")

-- [[ AYARLAR ]]
_G.SilentAim = false
_G.FOV = 100
_G.ESP_Enabled = false

-- [[ PENCERE OLUŞTURMA ]]
local Window = Rayfield:CreateWindow({
   Name = "Wyvern Pro",
   LoadingTitle = "Edit By Roxy",
   LoadingSubtitle = "Xeno Fix Version",
   ConfigurationSaving = { Enabled = false }
})

print("Wyvern Pro: Pencere Olusturuldu.")

-- SEKMELER
local CombatTab = Window:CreateTab("⚔️ Combat")
local ESPTab = Window:CreateTab("👁️ ESP")
local SkinTab = Window:CreateTab("👕 SkinChanger")

-- COMBAT İÇERİĞİ
CombatTab:CreateToggle({
   Name = "Silent Aim",
   CurrentValue = false,
   Callback = function(Value) 
       _G.SilentAim = Value 
       print("Silent Aim: ", Value)
   end,
})

CombatTab:CreateSlider({
   Name = "FOV",
   Range = {0, 500},
   Increment = 10,
   CurrentValue = 100,
   Callback = function(Value) _G.FOV = Value end,
})

-- ESP İÇERİĞİ
ESPTab:CreateToggle({
   Name = "Player Highlight (ESP)",
   CurrentValue = false,
   Callback = function(Value) _G.ESP_Enabled = Value end,
})

-- LOGIC (ÇALIŞTIRICI)
local FOVCircle = Drawing.new("Circle")
FOVCircle.Visible = false
FOVCircle.Thickness = 1
FOVCircle.Color = Color3.fromRGB(255, 255, 255)

game:GetService("RunService").RenderStepped:Connect(function()
    if _G.SilentAim then
        FOVCircle.Visible = true
        FOVCircle.Radius = _G.FOV
        FOVCircle.Position = game:GetService("UserInputService"):GetMouseLocation()
    else
        FOVCircle.Visible = false
    end

    if _G.ESP_Enabled then
        for _, v in pairs(game.Players:GetPlayers()) do
            if v ~= game.Players.LocalPlayer and v.Character then
                local h = v.Character:FindFirstChild("WyvernESP") or Instance.new("Highlight", v.Character)
                h.Name = "WyvernESP"
                h.FillColor = Color3.fromRGB(255, 0, 0)
            end
        end
    else
        for _, v in pairs(game.Players:GetPlayers()) do
            if v.Character and v.Character:FindFirstChild("WyvernESP") then
                v.Character.WyvernESP:Destroy()
            end
        end
    end
end)

print("Wyvern Pro: Sistem Aktif!")
