local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

_G.SilentAim = false
_G.AimKey = Enum.KeyCode.E
_G.FOV = 150
_G.ESP_Enabled = false
_G.AutoShoot = false

local Window = Rayfield:CreateWindow({
   Name = "Wyvern Pro",
   LoadingTitle = "Edit By Roxy",
   LoadingSubtitle = "V7 Visibility Update",
   ConfigurationSaving = { Enabled = false }
})

-- [[ ⚔️ COMBAT ]]
local CombatTab = Window:CreateTab("⚔️ Combat")
CombatTab:CreateToggle({
   Name = "Silent Aim Aktif",
   CurrentValue = false,
   Callback = function(v) _G.SilentAim = v end,
})
CombatTab:CreateKeybind({
   Name = "Kilitleme Tuşu",
   CurrentKeybind = "E",
   Callback = function(Key) _G.AimKey = Key end,
})
CombatTab:CreateToggle({
   Name = "Otomatik Ateş",
   CurrentValue = false,
   Callback = function(v) _G.AutoShoot = v end,
})
CombatTab:CreateSlider({
   Name = "FOV",
   Range = {0, 600},
   Increment = 10,
   CurrentValue = 150,
   Callback = function(v) _G.FOV = v end,
})

-- [[ 👁️ ESP ]]
local ESPTab = Window:CreateTab("👁️ ESP")
ESPTab:CreateToggle({
   Name = "Oyuncu ESP (Highlight)",
   CurrentValue = false,
   Callback = function(v) _G.ESP_Enabled = v end,
})

-- [[ 🚀 SİSTEM MOTORU ]]
local UIS = game:GetService("UserInputService")
local RunService = game:GetService("RunService")
local FOVCircle = Drawing.new("Circle")
FOVCircle.Thickness = 1.5
FOVCircle.Color = Color3.fromRGB(0, 255, 0) -- Yeşil FOV

-- Gelişmiş Görüş Kontrolü (Adamı görünce kilitlenir)
local function IsVisible(target)
    local cam = workspace.CurrentCamera
    local char = game.Players.LocalPlayer.Character
    if not char or not target then return false end
    
    local params = RaycastParams.new()
    params.FilterType = Enum.RaycastFilterType.Exclude
    params.FilterDescendantsInstances = {char, cam}
    
    local result = workspace:Raycast(cam.CFrame.Position, (target.Position - cam.CFrame.Position).Unit * 1000, params)
    
    -- Eğer önünde bir engel yoksa veya çarptığı şey hedefin kendisiyse görünürdür.
    return result == nil or result.Instance:IsDescendantOf(target.Parent)
end

RunService.RenderStepped:Connect(function()
    FOVCircle.Visible = _G.SilentAim
    FOVCircle.Radius = _G.FOV
    FOVCircle.Position = UIS:GetMouseLocation()

    -- 🔴 ESP SİSTEMİ (YENİDEN EKLENDİ)
    if _G.ESP_Enabled then
        for _, v in pairs(game.Players:GetPlayers()) do
            if v ~= game.Players.LocalPlayer and v.Character and v.Character:FindFirstChild("HumanoidRootPart") then
                local h = v.Character:FindFirstChild("RoxyHighlight") or Instance.new("Highlight", v.Character)
                h.Name = "RoxyHighlight"
                h.FillColor = Color3.fromRGB(255, 0, 0) -- Kırmızı ESP
                h.OutlineColor = Color3.fromRGB(255, 255, 255)
                h.Enabled = true
            end
        end
    else
        for _, v in pairs(game.Players:GetPlayers()) do
            if v.Character and v.Character:FindFirstChild("RoxyHighlight") then
                v.Character.RoxyHighlight:Destroy()
            end
        end
    end

    -- 🎯 KİLİTLENME (SADECE TUŞ VE GÖRÜŞ ODAKLI)
    local isRightClick = UIS:IsMouseButtonPressed(Enum.UserInputType.MouseButton2)
    
    if _G.SilentAim and UIS:IsKeyDown(_G.AimKey) and not isRightClick then
        local target = nil
        local dist = _G.FOV
        
        for _, v in pairs(game.Players:GetPlayers()) do
            if v ~= game.Players.LocalPlayer and v.Character and v.Character:FindFirstChild("HumanoidRootPart") then
                local p, vis = workspace.CurrentCamera:WorldToViewportPoint(v.Character.HumanoidRootPart.Position)
                
                if vis then
                    local m = (Vector2.new(p.X, p.Y) - UIS:GetMouseLocation()).Magnitude
                    if m < dist then
                        -- Sadece Görünürse Kilitle!
                        if IsVisible(v.Character.HumanoidRootPart) then
                            target = v.Character.HumanoidRootPart
                            dist = m
                        end
                    end
                end
            end
        end
        
        if target then
            workspace.CurrentCamera.CFrame = CFrame.new(workspace.CurrentCamera.CFrame.Position, target.Position)
            
            -- Auto Shoot (Virtual Input Manager)
            if _G.AutoShoot then
                game:GetService("VirtualInputManager"):SendMouseButtonEvent(0,0,0,true,game,0)
                task.wait()
                game:GetService("VirtualInputManager"):SendMouseButtonEvent(0,0,0,false,game,0)
            end
        end
    end
end)

Rayfield:Notify({Title = "Wyvern Pro V7", Content = "ESP ve Görüş Kontrolü Aktif!", Duration = 5})
