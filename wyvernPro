-- --- 🎯 [COMBAT & VISUAL ENGINE] ---
local FOVCircle = Drawing.new("Circle")
FOVCircle.Color = Color3.fromRGB(0, 255, 255)
FOVCircle.Thickness = 1
FOVCircle.Visible = true

local function GetTarget()
    local Target = nil
    local Dist = Wyvern.Combat.FOV
    for _, v in pairs(game.Players:GetPlayers()) do
        if v ~= game.Players.LocalPlayer and v.Character and v.Character:FindFirstChild(Wyvern.Combat.TargetPart) then
            if not (Wyvern.Visuals.TeamCheck and v.Team == game.Players.LocalPlayer.Team) then
                local Pos, Visible = workspace.CurrentCamera:WorldToViewportPoint(v.Character[Wyvern.Combat.TargetPart].Position)
                if Visible then
                    local Mag = (Vector2.new(Pos.X, Pos.Y) - game:GetService("UserInputService"):GetMouseLocation()).Magnitude
                    if Mag < Dist then 
                        Dist = Mag 
                        Target = v.Character[Wyvern.Combat.TargetPart] 
                    end
                end
            end
        end
    end
    return Target
end

-- --- 🔄 [CORE UPDATE LOOP] ---
game:GetService("RunService").RenderStepped:Connect(function()
    -- FOV Update
    FOVCircle.Visible = Wyvern.Visuals.FOVCircle
    FOVCircle.Radius = Wyvern.Combat.FOV
    FOVCircle.Position = game:GetService("UserInputService"):GetMouseLocation()

    local Char = game.Players.LocalPlayer.Character
    local Hum = Char and Char:FindFirstChild("Humanoid")
    local HRP = Char and Char:FindFirstChild("HumanoidRootPart")
    
    if Hum and HRP then
        -- Advanced WalkSpeed Bypass (Anti-detections dostu)
        if Wyvern.Movement.WalkSpeed > 16 then
            HRP.CFrame = HRP.CFrame + (Hum.MoveDirection * (Wyvern.Movement.WalkSpeed / 100))
        end
        -- Bhop
        if Wyvern.Movement.Bhop and game:GetService("UserInputService"):IsKeyDown(Enum.KeyCode.Space) and Hum.FloorMaterial ~= Enum.Material.Air then
            Hum.Jump = true
        end
    end

    -- Combat Logic
    if (Wyvern.Combat.Aimbot or Wyvern.Combat.SilentAim) and game:GetService("UserInputService"):IsKeyDown(Wyvern.Combat.AimKey) then
        local Target = GetTarget()
        if Target then
            if Wyvern.Combat.Aimbot then
                workspace.CurrentCamera.CFrame = CFrame.new(workspace.CurrentCamera.CFrame.Position, Target.Position)
            end
        end
    end
end)

