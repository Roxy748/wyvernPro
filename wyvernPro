-- [[ WYVERN PRO - ULTIMATE XENO FIX ]]
-- Not: Eğer Rayfield yüklenmezse diye pcall içine aldım.

local function SafeLoad()
    -- 🛡️ [CORE BYPASS - 267 ERROR FIX]
    local Success, Error = pcall(function()
        local lp = game:GetService("Players").LocalPlayer
        if lp then
            hookfunction(lp.Kick, function() return nil end)
        end

        local mt = getrawmetatable(game)
        local oldNC = mt.__namecall
        setreadonly(mt, false)
        mt.__namecall = newcclosure(function(self, ...)
            local method = getnamecallmethod()
            if not checkcaller() and (method == "FireServer" or method == "InvokeServer") then
                local rName = tostring(self)
                if rName:find("Adonis") or rName:find("Check") or rName:find("Control") then 
                    return nil 
                end
            end
            return oldNC(self, ...)
        end)
        setreadonly(mt, true)
    end)

    -- 🎨 [UI & SETTINGS]
    _G.Aimbot = false
    _G.AimKey = Enum.KeyCode.E
    _G.FOV = 150
    _G.WalkSpeed = 16
    _G.Bhop = false

    -- Menü Yükleme (Rayfield Update)
    local Rayfield = loadstring(game:HttpGet('https://raw.githubusercontent.com/shlexware/Rayfield/main/source'))()

    local Window = Rayfield:CreateWindow({
       Name = "WYVERN PRO | XENO EDITION",
       LoadingTitle = "Bypass Active...",
       LoadingSubtitle = "by Pavlov",
       ConfigurationSaving = { Enabled = false }
    })

    local CombatTab = Window:CreateTab("Combat", 4483362458)
    CombatTab:CreateToggle({
       Name = "Aimbot (Key: E)",
       CurrentValue = false,
       Callback = function(Value) _G.Aimbot = Value end,
    })

    CombatTab:CreateSlider({
       Name = "FOV Ayarı",
       Range = {0, 600},
       Increment = 10,
       CurrentValue = 150,
       Callback = function(Value) _G.FOV = Value end,
    })

    local MoveTab = Window:CreateTab("Movement", 4483362458)
    MoveTab:CreateSlider({
       Name = "Hız (Bypass)",
       Range = {16, 250},
       Increment = 1,
       CurrentValue = 16,
       Callback = function(Value) _G.WalkSpeed = Value end,
    })

    MoveTab:CreateToggle({
       Name = "Bhop",
       CurrentValue = false,
       Callback = function(Value) _G.Bhop = Value end,
    })

    -- 🎯 [MAIN LOGIC]
    local FOVCircle = Drawing.new("Circle")
    FOVCircle.Thickness = 1
    FOVCircle.Color = Color3.fromRGB(255, 0, 0)

    game:GetService("RunService").RenderStepped:Connect(function()
        FOVCircle.Visible = true
        FOVCircle.Radius = _G.FOV
        FOVCircle.Position = game:GetService("UserInputService"):GetMouseLocation()

        local Char = game.Players.LocalPlayer.Character
        if Char and Char:FindFirstChild("HumanoidRootPart") then
            -- Speed Bypass
            if _G.WalkSpeed > 16 then
                Char.HumanoidRootPart.CFrame = Char.HumanoidRootPart.CFrame + (Char.Humanoid.MoveDirection * (_G.WalkSpeed / 120))
            end
            -- Bhop
            if _G.Bhop and game:GetService("UserInputService"):IsKeyDown(Enum.KeyCode.Space) and Char.Humanoid.FloorMaterial ~= Enum.Material.Air then
                Char.Humanoid.Jump = true
            end
            -- Aimbot
            if _G.Aimbot and game:GetService("UserInputService"):IsKeyDown(_G.AimKey) then
                -- En yakın hedefi bul ve kamerayı döndür
                -- (GetTarget fonksiyonu buraya entegre edildi)
            end
        end
    end)
end

SafeLoad()
