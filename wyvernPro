-- [[ WYVERN PRO - MULTI-LANGUAGE EDITION ]]
-- Edit By Roxy | Turkish & English Support | Anti-RightClick

local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

-- Varsayılan Ayarlar
_G.SilentAim = false
_G.AimKey = Enum.KeyCode.E
_G.FOV = 150
_G.ESP = false
_G.AutoShoot = false
_G.Language = "TR" -- Varsayılan dil

-- Dil Sözlüğü
local lang = {
    TR = {
        Title = "Wyvern Pro | Roxy",
        Combat = "⚔️ Savaş",
        Visuals = "👁️ Görsel",
        SA_Active = "Silent Aim Aktif",
        Keybind = "Kilitleme Tuşu",
        AutoShoot = "Otomatik Ateş",
        FOV_Slider = "Görüş Alanı (FOV)",
        ESP_Toggle = "Oyuncu ESP",
        Notify_Title = "Başarılı",
        Notify_Msg = "Wyvern Pro Yüklendi!",
        Lang_Select = "Dil Seçiniz / Select Language"
    },
    EN = {
        Title = "Wyvern Pro | Roxy",
        Combat = "⚔️ Combat",
        Visuals = "👁️ Visuals",
        SA_Active = "Silent Aim Active",
        Keybind = "Aim Keybind",
        AutoShoot = "Auto Shoot",
        FOV_Slider = "Field of View (FOV)",
        ESP_Toggle = "Player ESP",
        Notify_Title = "Success",
        Notify_Msg = "Wyvern Pro Loaded!",
        Lang_Select = "Select Language"
    }
}

-- Dil Seçim Penceresi
local Window = Rayfield:CreateWindow({
   Name = "Wyvern Pro - Language Selection",
   LoadingTitle = "Edit By Roxy",
   LoadingSubtitle = "Youtube: Pavlov",
   ConfigurationSaving = { Enabled = false }
})

local LangTab = Window:CreateTab("🌍 Language")
LangTab:CreateButton({
   Name = "Türkçe",
   Callback = function()
      _G.Language = "TR"
      Rayfield:Destroy()
      InitHax()
   end,
})
LangTab:CreateButton({
   Name = "English",
   Callback = function()
      _G.Language = "EN"
      Rayfield:Destroy()
      InitHax()
   end,
})

-- Ana Hile Fonksiyonu
function InitHax()
    local L = lang[_G.Language]
    local MainWin = Rayfield:CreateWindow({
       Name = L.Title,
       LoadingTitle = "Roxy Hub",
       LoadingSubtitle = "Multi-Lang Edition",
       ConfigurationSaving = { Enabled = false }
    })

    -- ⚔️ COMBAT
    local CombatTab = MainWin:CreateTab(L.Combat)
    CombatTab:CreateToggle({
       Name = L.SA_Active,
       CurrentValue = false,
       Callback = function(v) _G.SilentAim = v end,
    })
    CombatTab:CreateKeybind({
       Name = L.Keybind,
       CurrentKeybind = "E",
       Callback = function(Key) _G.AimKey = Key end,
    })
    CombatTab:CreateToggle({
       Name = L.AutoShoot,
       CurrentValue = false,
       Callback = function(v) _G.AutoShoot = v end,
    })
    CombatTab:CreateSlider({
       Name = L.FOV_Slider,
       Range = {0, 600},
       Increment = 10,
       CurrentValue = 150,
       Callback = function(v) _G.FOV = v end,
    })

    -- 👁️ VISUALS
    local VisualTab = MainWin:CreateTab(L.Visuals)
    VisualTab:CreateToggle({
       Name = L.ESP_Toggle,
       CurrentValue = false,
       Callback = function(v) _G.ESP = v end,
    })

    -- MOTOR SİSTEMİ
    local UIS = game:GetService("UserInputService")
    local FOVCircle = Drawing.new("Circle")
    FOVCircle.Thickness = 1.5
    FOVCircle.Color = Color3.fromRGB(255, 255, 255)

    game:GetService("RunService").RenderStepped:Connect(function()
        FOVCircle.Visible = _G.SilentAim
        FOVCircle.Radius = _G.FOV
        FOVCircle.Position = UIS:GetMouseLocation()

        if _G.ESP then
            for _, v in pairs(game.Players:GetPlayers()) do
                if v ~= game.Players.LocalPlayer and v.Character then
                    local h = v.Character:FindFirstChild("RoxyESP") or Instance.new("Highlight", v.Character)
                    h.Name = "RoxyESP"
                    h.FillColor = Color3.fromRGB(255, 0, 0)
                end
            end
        end

        -- SAĞ TIK KONTROLÜ (MouseButton2 basılıysa kilitlenmez!)
        local RightClick = UIS:IsMouseButtonPressed(Enum.UserInputType.MouseButton2)
        if _G.SilentAim and UIS:IsKeyDown(_G.AimKey) and not RightClick then
            local target = nil
            local dist = _G.FOV
            for _, v in pairs(game.Players:GetPlayers()) do
                if v ~= game.Players.LocalPlayer and v.Character and v.Character:FindFirstChild("HumanoidRootPart") then
                    local p, vis = workspace.CurrentCamera:WorldToViewportPoint(v.Character.HumanoidRootPart.Position)
                    if vis then
                        local m = (Vector2.new(p.X, p.Y) - UIS:GetMouseLocation()).Magnitude
                        if m < dist then
                            target = v.Character.HumanoidRootPart
                            dist = m
                        end
                    end
                end
            end
            if target then
                workspace.CurrentCamera.CFrame = CFrame.new(workspace.CurrentCamera.CFrame.Position, target.Position)
                if _G.AutoShoot then
                    game:GetService("VirtualInputManager"):SendMouseButtonEvent(0,0,0,true,game,0)
                    task.wait()
                    game:GetService("VirtualInputManager"):SendMouseButtonEvent(0,0,0,false,game,0)
                end
            end
        end
    end)
    Rayfield:Notify({Title = L.Notify_Title, Content = L.Notify_Msg, Duration = 5})
end
