-- [[ WYVERN PRO - ULTIMATE EDITION ]]
-- Edit By Roxy | Youtube: Pavlov

local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

-- [[ AYAR DEĞİŞKENLERİ ]]
_G.SilentAim = false
_G.AimKey = Enum.KeyCode.E -- Varsayılan Tuş: E
_G.FOV = 150
_G.ESP_Enabled = false
_G.ESP_Color = Color3.fromRGB(255, 0, 0)

local Window = Rayfield:CreateWindow({
   Name = "Wyvern Pro",
   LoadingTitle = "Edit By Roxy",
   LoadingSubtitle = "Xeno Full Power",
   ConfigurationSaving = { Enabled = false }
})

-- [[ ⚔️ COMBAT TAB ]]
local CombatTab = Window:CreateTab("⚔️ Combat")

CombatTab:CreateToggle({
   Name = "Silent Aim Aktif",
   CurrentValue = false,
   Callback = function(Value) _G.SilentAim = Value end,
})

CombatTab:CreateKeybind({
   Name = "Silent Aim Tuşu",
   CurrentKeybind = "E",
   HoldToInteract = false,
   Flag = "AimKeybind",
   Callback = function(Keybind)
       _G.AimKey = Keybind
       Rayfield:Notify({Title = "Tuş Atandı", Content = "Yeni tuş: " .. tostring(Keybind), Duration = 2})
   end,
})

CombatTab:CreateSlider({
   Name = "Görüş Alanı (FOV)",
   Range = {0, 800},
   Increment = 10,
   CurrentValue = 150,
   Callback = function(Value) _G.FOV = Value end,
})

-- [[ 👁️ ESP TAB ]]
local ESPTab = Window:CreateTab("👁️ ESP")

ESPTab:CreateToggle({
   Name = "Oyuncu ESP (Highlight)",
   CurrentValue = false,
   Callback = function(Value) _G.ESP_Enabled = Value end,
})

ESPTab:CreateColorPicker({
    Name = "ESP Rengi",
    Color = Color3.fromRGB(255, 0, 0),
    Callback = function(Value) _G.ESP_Color = Value end
})

-- [[ 👕 SKINCHANGER TAB ]]
local SkinTab = Window:CreateTab("👕 SkinChanger")

SkinTab:CreateInput({
   Name = "Shirt (Gömlek) ID",
   PlaceholderText = "ID Girin...",
   Callback = function(Text)
       local char = game.Players.LocalPlayer.Character
       if char and char:FindFirstChildOfClass("Shirt") then
           char:FindFirstChildOfClass("Shirt").ShirtTemplate = "rbxassetid://" .. Text
       end
   end,
})

SkinTab:CreateInput({
    Name = "Pants (Pantolon) ID",
    PlaceholderText = "ID Girin...",
    Callback = function(Text)
        local char = game.Players.LocalPlayer.Character
        if char and char:FindFirstChildOfClass("Pants") then
            char:FindFirstChildOfClass("Pants").PantsTemplate = "rbxassetid://" .. Text
        end
    end,
 })

-- [[ 🚀 SİSTEM MOTORU (ARKA PLAN) ]]
local FOVCircle = Drawing.new("Circle")
FOVCircle.Thickness = 2
FOVCircle.Color = Color3.fromRGB(255, 255, 255)
FOVCircle.Filled = false

game:GetService("RunService").RenderStepped:Connect(function()
    -- FOV Halkası Güncelleme
    FOVCircle.Visible = _G.SilentAim
    FOVCircle.Radius = _G.FOV
    FOVCircle.Position = game:GetService("UserInputService"):GetMouseLocation()

    -- ESP Sistemi
    if _G.ESP_Enabled then
        for _, v in pairs(game.Players:GetPlayers()) do
            if v ~= game.Players.LocalPlayer and v.Character then
                local highlight = v.Character:FindFirstChild("RoxyESP") or Instance.new("Highlight", v.Character)
                highlight.Name = "RoxyESP"
                highlight.FillColor = _G.ESP_Color
            end
        end
    else
        for _, v in pairs(game.Players:GetPlayers()) do
            if v.Character and v.Character:FindFirstChild("RoxyESP") then
                v.Character.RoxyESP:Destroy()
            end
        end
    end

    -- Silent Aim (Tuş Kontrollü)
    if _G.SilentAim and game:GetService("UserInputService"):IsKeyDown(_G.AimKey) then
        local target = nil
        local maxDist = _G.FOV
        
        for _, v in pairs(game.Players:GetPlayers()) do
            if v ~= game.Players.LocalPlayer and v.Character and v.Character:FindFirstChild("HumanoidRootPart") then
                local pos, onScreen = game.Workspace.CurrentCamera:WorldToViewportPoint(v.Character.HumanoidRootPart.Position)
                if onScreen then
                    local mousePos = game:GetService("UserInputService"):GetMouseLocation()
                    local dist = (Vector2.new(pos.X, pos.Y) - mousePos).Magnitude
                    if dist < maxDist then
                        target = v.Character.HumanoidRootPart
                        maxDist = dist
                    end
                end
            end
        end
        
        if target then
            local cam = game.Workspace.CurrentCamera
            cam.CFrame = CFrame.new(cam.CFrame.Position, target.Position)
        end
    end
end)

Rayfield:Notify({Title = "Wyvern Pro Hazır!", Content = "Edit By Roxy - İyi çekimler!", Duration = 5})
